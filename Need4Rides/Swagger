                  fim: "2025-06-30T23:59:59.999Z"
                totais:
                  euros: 320.50
                  horas: 4.75
                subtotais:
                  - tipo: Combustão
                    euros: 200.00
                    horas: 3.00
                    taxis:
                      - id: "664f1a2b3c4d5e6f7a8b9c0d"
                        matricula: "AB-12-CD"
                        marca: Toyota
                        modelo: Corolla
                        tipo_motor: Combustão
                        euros: 200.00
                        horas: 3.00
                        registos:
                          - id: "664f1a2b3c4d5e6f7a8b9c0e"
                            data: "15/06/2025"
                            hora: "14:30"
                            posto: "Rua das Flores, 12"
                            valor: 200.00
                            litros: 45.0
                            kWh: null
                            duracao: "3.00"
                  - tipo: Elétrico
                    euros: 120.50
                    horas: 1.75
                    taxis:
                      - id: "664f1a2b3c4d5e6f7a8b9c1a"
